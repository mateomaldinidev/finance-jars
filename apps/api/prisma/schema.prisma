generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum MovementType {
  INCOME
  EXPENSE
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  baseCurrency String   @default("ARS")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  jars                       Jar[]
  movements                  Movement[]
  rules                      IncomeDistributionRule[]
  sessions                   AuthSession[]
  miscIncomeDistributions    IncomeDistribution[]
}

model AuthSession {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Jar {
  id                  String   @id @default(cuid())
  userId              String
  name                String
  color               String   @default("blue")
  description         String?
  percentageOfIncome  Int      @default(0)
  currency            String
  active              Boolean  @default(true)
  deletedAt           DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  movements Movement[]
  rules     IncomeDistributionRule[]

  @@unique([userId, name])
  @@index([userId, deletedAt])
  @@index([userId, active, deletedAt])
}

model Movement {
  id              String       @id @default(cuid())
  userId          String
  jarId           String?
  type            MovementType
  amount          Decimal
  currency        String
  occurredAt      DateTime
  note            String?
  externalRef     String?
  createdAt       DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  jar  Jar? @relation(fields: [jarId], references: [id], onDelete: SetNull)
  distribution IncomeDistribution?

  @@index([userId, occurredAt])
}

model IncomeDistribution {
  id                 String   @id @default(cuid())
  userId             String
  incomeMovementId   String   @unique
  totalAmount        Decimal
  currency           String
  distributedAmount  Decimal  @default(0)
  distributedAt      DateTime?
  createdAt          DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomeMovement Movement @relation(fields: [incomeMovementId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model IncomeDistributionRule {
  id         String   @id @default(cuid())
  userId     String
  jarId      String
  percentage Int
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  jar  Jar  @relation(fields: [jarId], references: [id], onDelete: Cascade)

  @@unique([userId, jarId])
}
