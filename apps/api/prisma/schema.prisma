generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum MovementType {
  INCOME
  EXPENSE
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  baseCurrency String   @default("ARS")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  jars       Jar[]
  movements  Movement[]
  rules      IncomeDistributionRule[]
}

model Jar {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  targetAmount Decimal?
  currency    String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  movements Movement[]
  rules     IncomeDistributionRule[]

  @@unique([userId, name])
}

model Movement {
  id              String       @id @default(cuid())
  userId          String
  jarId           String?
  type            MovementType
  amount          Decimal
  currency        String
  occurredAt      DateTime
  note            String?
  externalRef     String?
  createdAt       DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  jar  Jar? @relation(fields: [jarId], references: [id], onDelete: SetNull)

  @@index([userId, occurredAt])
}

model IncomeDistributionRule {
  id         String   @id @default(cuid())
  userId     String
  jarId      String
  percentage Int
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  jar  Jar  @relation(fields: [jarId], references: [id], onDelete: Cascade)

  @@unique([userId, jarId])
}
